{
  "name": "svelte-raster",
  "version": "0.5.1",
  "description": "A lightweight, resizable data-grid (raster) component for Svelte 5.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "svelte",
    "svelte5",
    "datagrid",
    "data-grid",
    "table",
    "raster",
    "component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christophsanz/raster.git"
  },
  "homepage": "https://github.com/christophsanz/raster#readme",
  "bugs": {
    "url": "https://github.com/christophsanz/raster/issues"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "package": "svelte-package && publint",
    "prepublishOnly": "bun run package",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/package": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^4.1.1",
    "publint": "^0.3.5",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}